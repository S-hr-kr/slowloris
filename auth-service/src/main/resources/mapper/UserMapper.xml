<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slowloris.auth.mapper.UserMapper">

    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.slowloris.auth.entity.User">
        select
            id,
            username,
            password,
            roles,
            status,
            create_time as createTime,
            update_time as updateTime,
            deleted
        from sys_user
        where username = #{username} and deleted = 0
    </select>

</mapper>